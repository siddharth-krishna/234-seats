# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Path to the SQLite database file (relative to project root)
DATABASE_URL=sqlite:///./234seats.db

# Secret key for signing session cookies — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Set to "false" in production
DEBUG=true
